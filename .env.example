# Oculus Environment Variables
# Copy this file to .env.local and fill in your values

# Database (Supabase/Postgres)
DATABASE_URL=postgresql://postgres.xxx:password@aws-1-region.pooler.supabase.com:6543/postgres

# Pinecone - Vector Database
PINECONE_API_KEY=pcsk_xxx
PINECONE_INDEX_NAME=oculus

# NVIDIA NIM - LLM API
NIM_API_KEY=nvapi-xxx

# Google AI - Embeddings
GOOGLE_GENERATIVE_AI_API_KEY=AIza-xxx

# Jina AI - Web Scraping
JINA_API_KEY=jina_xxx
